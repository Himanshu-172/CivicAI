{
  "name": "civic-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@civic-ai/api",
    "dev:web": "npm run dev --workspace=@civic-ai/web",
    "lint": "npm run lint --workspace=@civic-ai/api",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
